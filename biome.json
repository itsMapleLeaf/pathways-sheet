{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**/*",
			"!node_modules",
			"!**/node_modules",
			"!**/convex/_generated",
			"!**/routeTree.gen.ts",
			"!!**/dist"
		]
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"suspicious": "off",
			"complexity": {
				"noBannedTypes": "off"
			},
			"style": {
				"useTemplate": "off"
			},
			"nursery": {
				"useSortedClasses": {
					"fix": "safe",
					"level": "info",
					"options": {
						"attributes": ["className"],
						"functions": ["clsx", "cva", "tw", "twMerge", "cn", "twJoin", "tv"]
					}
				}
			}
		}
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
